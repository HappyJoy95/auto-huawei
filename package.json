{
  "name": "auto-controller",
  "version": "0.1.1-mac",
  "description": "自动化任务控制器 - macOS 版本",
  "main": "packages/main/dist/main.cjs",
  "author": "happy",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/watch.mjs",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "cd packages/main && npx vite build",
    "build:preload": "cd packages/preload && npx vite build",
    "build:renderer": "cd packages/renderer && npx vite build",
    "start": "NODE_ENV=production ./node_modules/electron/dist/Electron.app/Contents/MacOS/Electron .",
    "start:dev": "NODE_ENV=development ./node_modules/electron/dist/Electron.app/Contents/MacOS/Electron ."
  },
  "devDependencies": {
    "@arco-design/web-vue": "^2.55.0",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.28.0",
    "less": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "vue-tsc": "^1.8.25"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "pinia": "^2.1.7",
    "python-shell": "^5.0.0"
  }
}
