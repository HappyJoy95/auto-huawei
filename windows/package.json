{
  "name": "auto-controller",
  "version": "0.3.0",
  "description": "自动化任务控制器 - 支持模块化任务调度与通知推送",
  "main": "packages/main/dist/main.cjs",
  "author": "happy",
  "license": "MIT",
  "scripts": {
    "dev": "node ../shared/scripts/watch.mjs",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "npx vite build --config ../shared/packages/main/vite.config.ts",
    "build:preload": "npx vite build --config ../shared/packages/preload/vite.config.ts",
    "build:renderer": "npx vite build --config ../shared/packages/renderer/vite.config.ts",
    "start": "set NODE_ENV=production && .\\node_modules\\electron\\dist\\electron.exe .",
    "start:dev": "set NODE_ENV=development && .\\node_modules\\electron\\dist\\electron.exe ."
  },
  "devDependencies": {
    "@arco-design/web-vue": "^2.55.0",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.28.0",
    "less": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "vue-tsc": "^1.8.25"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "pinia": "^2.1.7",
    "python-shell": "^5.0.0"
  }
}
