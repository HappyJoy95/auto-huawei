# ========================================
# 自动化控制器环境变量配置
# 启动时若 .env 不存在会自动从本文件复制
# ========================================

# ----- SMTP 邮件配置 -----
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ----- 企业微信 Webhook -----
WECHAT_WEBHOOK=

# ----- 企业微信应用消息配置 -----
WECHAT_CORP_ID=
WECHAT_AGENT_ID=
WECHAT_AGENT_SECRET=
WECHAT_DEFAULT_USERID=

# ----- 京东到家账号 -----
JDDJ_USERNAME=
JDDJ_PASSWORD=
